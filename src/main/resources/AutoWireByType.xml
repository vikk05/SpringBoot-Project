<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="
        http://www.springframework.org/schema/beans http://www.springframework.org/schema/beans/spring-beans.xsd">

    <!-- bean definitions here -->

    <bean id="specify" class="car.example.AutowireByType.specification">
        <property  name="make" value="Land Rover"/>
        <property name="model" value="Defender"/>
    </bean>

    <bean id="myCar" class="car.example.AutowireByType.car" autowire="byType"/>

    <!--In autowiring byType, Spring injects a dependency
    by matching the type of the dependent object
     with the type of a bean available in the container.-->


</beans>