<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="
        http://www.springframework.org/schema/beans http://www.springframework.org/schema/beans/spring-beans.xsd">

    <!-- bean definitions here -->

    <bean id="UserDatabase" class="com.name.LooseCoupling.UserDatabaseProvider"/>
    <bean id="newDatabase" class="com.name.LooseCoupling.NewDataBaseProvider"/>
    <bean id="webServiceData" class="com.name.LooseCoupling.WebServiceDataProvider"/>


    <bean id="userDatabaseWithUserManager" class="com.name.LooseCoupling.UserManager">
        <constructor-arg ref="UserDatabase"/>
    </bean>
    <bean id="newDatabaseWithUserManager" class="com.name.LooseCoupling.UserManager">
        <constructor-arg ref="newDatabase"/>
    </bean>
    <bean id="webServiceDataWithUserManager" class="com.name.LooseCoupling.UserManager">
        <constructor-arg ref="webServiceData"/>
    </bean>

</beans>